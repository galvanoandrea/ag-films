# ─── Supabase ───────────────────────────────────────────────
# Project URL and anon key from: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (never expose to browser) from: Settings → API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ─────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret: stripe listen --forward-to localhost:3000/api/webhook
# Or from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Admin ──────────────────────────────────────────────────
# Password for the admin panel (plain text, compared server-side)
ADMIN_PASSWORD=change-me-to-something-strong

# Long random string used as the session cookie value after login
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=replace-with-output-of-openssl-rand-hex-32

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
